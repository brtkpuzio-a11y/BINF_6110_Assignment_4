# 10.  FEATURE PLOTS

# Shared minimal theme for all feature plots
fp_theme <- theme(
  plot.title = element_text(size = 10, face = "italic"),
  axis.title = element_blank(), axis.text = element_blank(),
  axis.ticks = element_blank(), legend.position = "none"
)

# Helper: add legend to first panel only
add_legend <- function(p) {
  p[[1]] <- p[[1]] + theme(
    legend.position = "right",
    legend.key.height = unit(0.8, "cm"), legend.key.width = unit(0.3, "cm"),
    legend.text = element_text(size = 7), legend.title = element_blank()
  )
  p
}

ggsave("featureplot_KNIIFE_markers.pdf",
  add_legend(
    FeaturePlot(seurat_obj,
      reduction = "umap", ncol = 3, pt.size = 0.4, order = TRUE,
      features = c("Pigr", "Krt13", "Krt5", "Cd274", "Epcam"),
      cols = c("grey90", "#67000D")
    ) &
      fp_theme & theme(panel.background = element_rect(fill = "white", color = NA))
  ) + plot_annotation(
    title = "Feature plots – KNIIFE & epithelial markers",
    subtitle = "Expression overlaid on UMAP; grey = not detected",
    theme = theme(
      plot.title = element_text(size = 13, face = "bold"),
      plot.subtitle = element_text(size = 9, color = "grey40")
    )
  ),
  width = 12, height = 8
)


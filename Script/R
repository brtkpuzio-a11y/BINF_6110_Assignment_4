# 11.  DIFFERENTIAL EXPRESSION ANALYSIS

Idents(seurat_obj) <- seurat_obj$seurat_clusters

# Cluster 5 and 6: positive markers vs all other clusters
for (cl in c("5", "6")) {
  markers <- FindMarkers(seurat_obj,
    ident.1 = cl, only.pos = TRUE,
    min.pct = 0.35, logfc.threshold = 0.5, test.use = "bimod"
  )
  markers$gene <- rownames(markers)
  cat("\n── Cluster", cl, ": top 20 markers ──\n")
  print(arrange(markers, desc(avg_log2FC)) %>% head(20))
  write.csv(markers, paste0("DE_cluster", cl, "_markers.csv"), row.names = TRUE)
  cat("\nSingleR labels for cluster", cl, ":\n")
  print(table(seurat_obj$singler_label[seurat_obj$seurat_clusters == cl]))
  assign(paste0("cluster", cl, "_markers"), markers)
}

# Top-4 marker violins per cluster across timepoints
for (cl in c("5", "6")) {
  top4 <- get(paste0("cluster", cl, "_markers")) %>%
    arrange(desc(avg_log2FC)) %>%
    head(4) %>%
    pull(gene)
  ggsave(paste0("violin_cluster", cl, "_timepoints.pdf"),
    VlnPlot(subset(seurat_obj, subset = seurat_clusters == cl),
      features = top4, ncol = 2, pt.size = 0, group.by = "timepoint"
    ) +
      plot_annotation(title = paste("Cluster", cl, "— top marker expression across timepoints")),
    width = 10, height = 8
  )
}

# Cluster 5 (Neutrophils): Naive vs D14
# Cluster 6 (NKT): Naive vs D05
cl_timepoints <- list("5" = c("Naive", "D14"), "6" = c("Naive", "D05"))

for (cl in c("5", "6")) {
  tps <- cl_timepoints[[cl]]
  sub <- subset(seurat_obj, subset = seurat_clusters == cl & timepoint %in% tps)
  sub$timepoint <- droplevels(sub$timepoint)
  Idents(sub) <- "timepoint"

  de <- FindMarkers(sub,
    ident.1 = tps[2], ident.2 = tps[1],
    test.use = "wilcox", min.pct = 0.15, logfc.threshold = 0.20
  )
  de$gene <- rownames(de)
  write.csv(de, paste0("DE_cluster", cl, "_", tps[2], "vsNaive.csv"), row.names = TRUE)

  cat("\n── Cluster", cl, ":", tps[2], "vs Naive — top hits ──\n")
  print(arrange(de, desc(avg_log2FC)) %>% head(20))

  assign(paste0("cluster", cl, "_de_timepoint"), de)
}


# FindAllMarkers for heatmap of top 5 genes per cluster
all_cluster_markers <- FindAllMarkers(seurat_obj,
  only.pos = TRUE,
  min.pct = 0.35, logfc.threshold = 0.5, test.use = "bimod"
)
write.csv(all_cluster_markers, "DE_all_cluster_markers.csv", row.names = TRUE)

top5_per_cluster <- all_cluster_markers %>%
  filter(p_val_adj < 0.05) %>%
  group_by(cluster) %>%
  slice_max(order_by = avg_log2FC, n = 5) %>%
  ungroup()

ggsave("heatmap_top5_per_cluster.pdf",
  DoHeatmap(seurat_obj,
    features = top5_per_cluster$gene,
    group.by = "seurat_clusters", angle = 0, size = 3
  ) +
    scale_fill_gradientn(colours = c("#2166AC", "white", "#D73027"), na.value = "white") +
    theme(axis.text.y = element_text(size = 5), legend.text = element_text(size = 8)) +
    ggtitle("Top 5 marker genes per cluster"),
  width = 16, height = 12
)

# RM NK cells + Macrophages: D08 vs Naive
# Note: pseudobulk DESeq2 not possible due to insufficient sample replicates per group
# Wilcoxon test used instead — acknowledged as limitation in methods
rm_innate <- subset(rm_obj,
  subset = singler_label %in% c("NK cells", "Macrophages") &
    timepoint %in% c("Naive", "D08")
)
rm_innate$timepoint <- droplevels(rm_innate$timepoint)

cat("\nInnate cells for DE (RM, Naive vs D08):", ncol(rm_innate), "\n")
print(table(rm_innate$singler_label, rm_innate$timepoint))

Idents(rm_innate) <- "timepoint"

de_innate_8dpi <- FindMarkers(
  rm_innate,
  ident.1         = "D08",
  ident.2         = "Naive",
  test.use        = "wilcox",
  min.pct         = 0.15,
  logfc.threshold = 0.20
)

write.csv(de_innate_8dpi, "DE_innate_D08vsNaive.csv", row.names = TRUE)

de_innate_8dpi <- de_innate_8dpi %>%
  mutate(
    gene = rownames(.),
    sig = p_val_adj < 0.05,
    direction = ifelse(avg_log2FC > 0, "Up (D08)", "Down (D08)"),
    label = ifelse(gene %in% c(
      "Nkg7", "Gzmb", "Prf1", "Ifng", "C1qa",
      "Cxcl9", "Cxcl10", "Il6", "Tnf",
      "Ifit1", "Isg15", "Mx1"
    ), gene, NA)
  )
ggsave("volcano_innate_D08vsNaive.pdf",
  ggplot(
    de_innate_8dpi,
    aes(avg_log2FC, -log10(p_val_adj),
      colour = interaction(sig, direction), label = label
    )
  ) +
    geom_point(alpha = 0.6, size = 1.2) +
    geom_text_repel(
      size = 3, max.overlaps = 20, na.rm = TRUE,
      fontface = "italic", colour = "black"
    ) +
    scale_colour_manual(name = "", values = c(
      "FALSE.Down (D08)" = "grey70", "FALSE.Up (D08)" = "grey70",
      "TRUE.Down (D08)" = "#2166AC", "TRUE.Up (D08)" = "#D73027"
    )) +
    geom_vline(xintercept = c(-0.25, 0.25), linetype = "dashed", colour = "grey40") +
    geom_hline(yintercept = -log10(0.05), linetype = "dashed", colour = "grey40") +
    labs(
      title = "DE: NK + Macrophage cells — D08 vs Naive (RM)",
      subtitle = "Wilcoxon | Highlighted: cytotoxic and myeloid activation genes",
      x = "Average log2 fold-change", y = "-log10 adjusted p-value"
    ) +
    theme_classic(base_size = 12) +
    theme(legend.position = "top"),
  width = 9, height = 7
)



library(celldex)

set.seed(42)

# 1.  DATA LOADING

seurat_obj <- readRDS("seurat_ass4.rds")

seurat_obj$timepoint <- sub("^([^_]+)_.*", "\\1", seurat_obj$orig.ident)
seurat_obj$region <- sub("^[^_]+_([^.]+)\\..*", "\\1", seurat_obj$orig.ident)

seurat_obj$timepoint <- factor(
  seurat_obj$timepoint,
  levels = intersect(c("Naive", "D02", "D05", "D08", "D14"), unique(seurat_obj$timepoint))
)

cat("Loaded", ncol(seurat_obj), "cells and", nrow(seurat_obj), "genes.\n")


# 2.  QUALITY CONTROL

seurat_obj[["percent.mt"]] <- PercentageFeatureSet(seurat_obj, pattern = "^mt-")

ggsave("qc_violin_prefilt.pdf",
  VlnPlot(seurat_obj,
    features = c("nFeature_RNA", "nCount_RNA", "percent.mt"),
    ncol = 3, pt.size = 0, group.by = "orig.ident"
  ) +
    plot_annotation(title = "QC metrics before filtering"),
  width = 14, height = 5
)

print(FeatureScatter(seurat_obj, feature1 = "nCount_RNA", feature2 = "percent.mt"))

seurat_obj <- subset(seurat_obj,
  subset = nFeature_RNA > 500 & nFeature_RNA < 2500 &
    nCount_RNA > 750 & nCount_RNA < 6000 &
    percent.mt < 8
)

cat("After QC:", ncol(seurat_obj), "cells remain.\n")

print(FeatureScatter(seurat_obj, feature1 = "nCount_RNA", feature2 = "percent.mt"))

ggsave("qc_violin_postfilt.pdf",
  VlnPlot(seurat_obj,
    features = c("nFeature_RNA", "nCount_RNA", "percent.mt"),
    ncol = 3, pt.size = 0, group.by = "orig.ident"
  ) +
    plot_annotation(title = "QC metrics after filtering"),
  width = 14, height = 5
)


# 3.  NORMALISATION, CELL CYCLE REGRESSION & VARIABLE FEATURES

seurat_obj <- NormalizeData(seurat_obj, normalization.method = "LogNormalize")

seurat_obj <- CellCycleScoring(
  seurat_obj,
  s.features   = str_to_title(cc.genes$s.genes),
  g2m.features = str_to_title(cc.genes$g2m.genes),
  set.ident    = FALSE
)

seurat_obj <- FindVariableFeatures(seurat_obj, selection.method = "vst", nfeatures = 3000)

seurat_obj <- ScaleData(seurat_obj,
  vars.to.regress = c("percent.mt", "S.Score", "G2M.Score")
)


# 4.  PCA & ELBOW PLOT

seurat_obj <- RunPCA(seurat_obj, features = VariableFeatures(seurat_obj), verbose = TRUE)

N_PCS <- 14

ggsave("elbow_plot.pdf",
  ElbowPlot(seurat_obj, ndims = 50) +
    ggtitle("Elbow plot – selecting number of PCs") +
    geom_vline(xintercept = N_PCS, linetype = "dashed", colour = "red") +
    annotate("text",
      x = 32, y = 3, hjust = 0, colour = "red",
      label = paste("Selected:", N_PCS, "PCs")
    ),
  width = 7, height = 4
)


# 5.  HARMONY INTEGRATION

seurat_obj <- RunHarmony(
  seurat_obj,
  group.by.vars    = "orig.ident",
  dims.use         = 1:N_PCS,
  assay.use        = "RNA",
  plot_convergence = FALSE,
  verbose          = TRUE
)


# 6.  CLUSTERING + UMAP

seurat_obj <- FindNeighbors(seurat_obj, reduction = "harmony", dims = 1:N_PCS)
seurat_obj <- FindClusters(seurat_obj, resolution = 0.3, cluster.name = "seurat_clusters")
seurat_obj <- RunUMAP(seurat_obj,
  reduction = "harmony", dims = 1:N_PCS,
  n.neighbors = 30, reduction.name = "umap", verbose = TRUE
)

# UMAPs coloured by cluster, tissue, timepoint, and sample
ggsave("umap_clusters.pdf",
  DimPlot(seurat_obj, reduction = "umap", label = TRUE, repel = TRUE, pt.size = 0.3) +
    ggtitle("UMAP – Seurat clusters") + NoLegend(),
  width = 8, height = 7
)

ggsave("umap_region.pdf",
  DimPlot(seurat_obj,
    reduction = "umap", group.by = "organ_custom", pt.size = 0.3,
    cols = c("OM" = "#FF0000", "RM" = "#0099FF", "LNG" = "#00CC00")
  ) +
    ggtitle("UMAP – Tissue region"),
  width = 8, height = 6
)

ggsave("umap_timepoint.pdf",
  DimPlot(seurat_obj,
    reduction = "umap", group.by = "timepoint", pt.size = 0.3,
    cols = c(
      "Naive" = "#E6E6E6", "D02" = "#FF0000", "D05" = "#FF9900",
      "D08" = "#FFFF00", "D14" = "#00CC00"
    )
  ) +
    ggtitle("UMAP – Timepoint"),
  width = 8, height = 6
)

ggsave("umap_batch_check.pdf",
  DimPlot(seurat_obj,
    reduction = "umap", group.by = "orig.ident", pt.size = 0.5,
    cols = rainbow(length(unique(seurat_obj$orig.ident))), shuffle = TRUE
  ) +
    ggtitle("UMAP – Sample (batch check)") + theme(legend.position = "none"),
  width = 8, height = 6
)

# Dot plot of canonical marker genes across all clusters
Idents(seurat_obj) <- seurat_obj$seurat_clusters

ggsave("dotplot_markers_by_cluster.pdf",
  DotPlot(seurat_obj,
    cols = c("lightgrey", "#67000D"), dot.scale = 6,
    features = c(
      "Krt13", "Epcam", "Pigr",
      "Nkg7", "Gzmb", "Prf1",
      "C1qa", "Csf1r", "Adgre1",
      "Ly6c2", "S100a8",
      "Ms4a1", "Cd79a",
      "Cd3e", "Cd8a",
      "Ifitm3", "Isg15", "Oas1a"
    )
  ) +
    RotatedAxis() +
    labs(title = "Marker gene expression across Seurat clusters", x = NULL, y = "Cluster") +
    theme(
      axis.text.x = element_text(size = 9, face = "italic"),
      axis.text.y = element_text(size = 9),
      plot.title = element_text(size = 12, face = "bold")
    ),
  width = 14, height = 7
)


# 7.  MANUAL ANNOTATION — KNIIFE

# Module score from four KNIIFE markers; clusters >= 0.20 labelled KNIIFE
seurat_obj <- AddModuleScore(seurat_obj,
  seed = 42, name = "celltype_score",
  features = list("KNIIFE" = c("Krt13", "Il1a", "Cd274", "Cxcl16"))
)

Idents(seurat_obj) <- seurat_obj$seurat_clusters

cluster_scores <- tapply(seurat_obj$celltype_score1, Idents(seurat_obj), mean)
cluster_labels <- ifelse(cluster_scores >= 0.20, "KNIIFE", "Other")
names(cluster_labels) <- names(cluster_scores)

print(data.frame(
  Cluster = names(cluster_labels), Cell_Type = cluster_labels,
  Score = round(cluster_scores, 4)
))

seurat_obj$cell_type <- cluster_labels[as.character(seurat_obj$seurat_clusters)]
cat("\n── Cell type composition ──\n")
print(table(seurat_obj$cell_type))

Idents(seurat_obj) <- seurat_obj$cell_type

ggsave("umap_annotated_KNIIFE.pdf",
  DimPlot(seurat_obj,
    reduction = "umap", label = TRUE, repel = TRUE,
    label.size = 3, pt.size = 0.3,
    cols = c("KNIIFE" = "#FF7F00", "Other" = "#CCCCCC")
  ) +
    ggtitle("UMAP – KNIIFE vs Other"),
  width = 13, height = 9
)


# 8.  SINGLER ANNOTATION

# Automated annotation against ImmGen reference
pred <- SingleR(
  test      = GetAssayData(seurat_obj, assay = "RNA", layer = "data"),
  ref       = celldex::ImmGenData(),
  labels    = celldex::ImmGenData()$label.main,
  de.method = "wilcox"
)

seurat_obj$singler_label <- pred$labels
seurat_obj$singler_pruned <- pred$pruned.labels

cat("\n── SingleR label composition ──\n")
print(table(seurat_obj$singler_label))
cat("\nLow-confidence cells:", sum(is.na(seurat_obj$singler_pruned)), "\n")

Idents(seurat_obj) <- seurat_obj$singler_pruned

ggsave("umap_annotated_singler.pdf",
  DimPlot(seurat_obj,
    reduction = "umap", label = TRUE, repel = TRUE,
    label.size = 3, pt.size = 0.3, na.value = "lightgrey"
  ) +
    ggtitle("UMAP – SingleR annotation (ImmGenData)"),
  width = 13, height = 9
)

pdf("singler_score_heatmap.pdf", width = 14, height = 8)
plotScoreHeatmap(pred)
dev.off()
pdf("singler_delta_distribution.pdf", width = 10, height = 6)
plotDeltaDistribution(pred)
dev.off()



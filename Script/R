# ORA GO BP — helper function to avoid repetition
run_ora <- function(markers, label) {
  up <- markers %>%
    filter(avg_log2FC > 0.5, p_val_adj < 0.05) %>%
    pull(gene)
  bg <- rownames(seurat_obj)
  g <- bitr(up, fromType = "SYMBOL", toType = "ENTREZID", OrgDb = org.Mm.eg.db)
  b <- bitr(bg, fromType = "SYMBOL", toType = "ENTREZID", OrgDb = org.Mm.eg.db)
  ora <- enrichGO(
    gene = g$ENTREZID, universe = b$ENTREZID, OrgDb = org.Mm.eg.db,
    ont = "BP", pAdjustMethod = "BH", pvalueCutoff = 0.05, qvalueCutoff = 0.2,
    readable = TRUE
  )
  if (nrow(ora) > 0) {
    ggsave(paste0("ORA_GO_BP_", label, ".pdf"),
      dotplot(ora, showCategory = 20, font.size = 9) +
        ggtitle(paste("ORA – GO Biological Process\n", label, "upregulated markers")) +
        theme(axis.text.y = element_text(size = 8)),
      width = 10, height = 8
    )
  } else {
    cat("No significant ORA terms for", label, "\n")
  }
}

run_ora(cluster5_markers, "cluster5")
run_ora(cluster6_markers, "cluster6")

for (cl in c("5", "6")) {
  de <- get(paste0("cluster", cl, "_de_timepoint"))
  gene_list <- de %>%
    filter(!is.na(avg_log2FC)) %>%
    arrange(desc(avg_log2FC)) %>%
    {
      setNames(.$avg_log2FC, .$gene)
    }

  gsea_res <- GSEA(gene_list,
    verbose = FALSE, pvalueCutoff = 0.05,
    TERM2GENE = msigdbr(species = "Mus musculus", category = "H") %>%
      dplyr::select(gs_name, gene_symbol)
  )

  if (nrow(gsea_res) > 0) {
    ggsave(paste0("GSEA_Hallmark_cluster", cl, ".pdf"),
      dotplot(gsea_res, showCategory = 15, split = ".sign") +
        facet_grid(. ~ .sign) +
        ggtitle(paste("GSEA Hallmark – Cluster", cl)) +
        theme(axis.text.y = element_text(size = 8)),
      width = 14, height = 8
    )
  } else {
    cat("No significant GSEA terms for cluster", cl, "\n")
  }
}


# 13.  CELL COMPOSITION ANALYSIS

# RM cell-type composition across timepoints
ggsave("composition_bar_RM_timepoint.pdf",
  seurat_obj@meta.data %>%
    filter(organ_custom == "RM", !is.na(singler_pruned)) %>%
    count(timepoint, singler_pruned) %>%
    group_by(timepoint) %>% mutate(fraction = n / sum(n)) %>% ungroup() %>%
    ggplot(aes(timepoint, fraction, fill = singler_pruned)) +
    geom_bar(stat = "identity", position = "stack", colour = "white", linewidth = 0.2) +
    labs(
      title = "Cell-type composition of RM across primary infection",
      x = "Timepoint", y = "Fraction of RM cells", fill = "Cell type"
    ) +
    theme_classic(base_size = 11) +
    theme(
      legend.text = element_text(size = 8),
      axis.text.x = element_text(angle = 30, hjust = 1)
    ),
  width = 10, height = 6
)

# Krt13 mean expression kinetics in RM as KNIIFE proxy
rm_expr <- GetAssayData(subset(seurat_obj, subset = organ_custom == "RM"),
  assay = "RNA", layer = "data"
)["Krt13", ]

krt13_tp <- seurat_obj@meta.data %>%
  filter(organ_custom == "RM") %>%
  mutate(Krt13 = FetchData(seurat_obj, vars = "Krt13")[rownames(.), 1]) %>%
  group_by(timepoint) %>%
  summarise(mean_Krt13 = mean(Krt13), .groups = "drop")

ggsave("composition_kinetics_KNIIFE_RM.pdf",
  ggplot(krt13_tp, aes(timepoint, mean_Krt13, group = 1)) +
    geom_line(linewidth = 1.2, colour = "#FF7F00") +
    geom_point(size = 3, colour = "#FF7F00") +
    labs(
      title = "Krt13 mean expression across IAV infection (RM)",
      x = "Timepoint", y = "Mean log-normalised Krt13 expression"
    ) +
    theme_classic(base_size = 12),
  width = 9, height = 5
)

# Cross-tissue composition at D08
ggsave("composition_bar_tissue_D08.pdf",
  seurat_obj@meta.data %>%
    filter(timepoint == "D08", !is.na(singler_pruned)) %>%
    count(organ_custom, singler_pruned) %>%
    group_by(organ_custom) %>% mutate(fraction = n / sum(n)) %>% ungroup() %>%
    ggplot(aes(organ_custom, fraction, fill = singler_pruned)) +
    geom_bar(stat = "identity", position = "stack", colour = "white", linewidth = 0.2) +
    labs(
      title = "Cell-type composition by tissue at D08",
      x = "Tissue", y = "Fraction of cells", fill = "Cell type"
    ) +
    theme_classic(base_size = 11) +
    theme(legend.text = element_text(size = 8)),
  width = 8, height = 6
)
